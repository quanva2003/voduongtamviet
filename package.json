{
  "name": "vdtv",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-sitemap.js",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "dev:v2": "vite --config vite.config.v2.ts",
    "build:v2": "tsc -p tsconfig.v2.json && vite build --config vite.config.v2.ts",
    "preview:v2": "vite preview --config vite.config.v2.ts",
    "lint": "eslint src-v2/ --config eslint.config.v2.mjs",
    "typecheck": "tsc -p tsconfig.v2.json",
    "test": "vitest run --config vitest.config.v2.ts",
    "test:watch": "vitest --config vitest.config.v2.ts",
    "test:coverage": "vitest run --config vitest.config.v2.ts --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/noto-serif-jp": "^5.2.9",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/vite": "^4.1.13",
    "@types/aos": "^3.0.7",
    "antd": "^6.3.7",
    "aos": "^2.3.4",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.553.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.74.0",
    "react-i18next": "^17.0.6",
    "react-router-dom": "^7.9.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.13",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.36.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9.36.0",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-boundaries": "^4.2.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  }
}
